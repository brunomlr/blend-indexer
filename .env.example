# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/blend_backfill

# Google Cloud BigQuery (for historical backfill)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Server Configuration
PORT=3000
NODE_ENV=development

# Goldsky Webhook Configuration
# Generate with: openssl rand -hex 32
GOLDSKY_WEBHOOK_SECRET=your_webhook_secret_here

# Stellar Network Configuration
STELLAR_NETWORK=mainnet
STELLAR_RPC_URL=https://soroban-rpc.stellar.org

# Optional: Monitoring & Logging
LOG_LEVEL=info
