{
  "name": "stellar-events-stream",
  "version": "1.0.0",
  "description": "Goldsky-powered Blend Protocol events streaming to Neon PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "discover": "tsx src/scripts/discover-assets.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@blend-capital/blend-sdk": "^2.2.0",
    "@google-cloud/bigquery": "^7.9.0",
    "@neondatabase/serverless": "^0.9.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.29.0",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "drizzle-kit": "^0.20.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
