{
  "name": "blend-backfill-backend",
  "version": "1.0.0",
  "description": "Backend for Blend Protocol data backfill system",
  "main": "dist/api/server.js",
  "scripts": {
    "setup": "ts-node src/scripts/setup-db.ts",
    "migrate": "ts-node src/scripts/migrate-to-ledger-based.ts",
    "migrate:add-rates": "ts-node src/scripts/add-rates-to-positions.ts",
    "recreate": "ts-node src/scripts/recreate-user-positions.ts",
    "backfill:bigquery": "ts-node src/scripts/run-bigquery-backfill.ts",
    "backfill:lp-prices": "ts-node src/scripts/run-lp-price-backfill.ts",
    "sync:pools-tokens": "ts-node src/scripts/sync-pools-tokens.ts",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch src/api/server.ts",
    "dev:frontend": "npm run --prefix frontend dev",
    "build": "tsc && npm run build:frontend",
    "build:frontend": "npm run --prefix frontend build",
    "start": "node dist/api/server.js"
  },
  "dependencies": {
    "@blend-capital/blend-sdk": "^3.2.1",
    "@google-cloud/bigquery": "^7.3.0",
    "@stellar/stellar-sdk": "^14.3.2",
    "axios": "^1.6.7",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "multer": "^2.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.0",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
